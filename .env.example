# =============================================================================
# SiteOwlQA_App — Environment Configuration (Non-Sensitive)
# 
# IMPORTANT: Sensitive data (tokens, passwords, credentials) is NOT stored here.
# See: User Configuration below
# =============================================================================

# --- User Configuration (SENSITIVE - DO NOT COMMIT) -------------------------
# 
# Your sensitive configuration lives in: ~/.siteowlqa/config.json
# 
# To create this file, run the interactive setup wizard:
#   python -m siteowlqa.setup_config
# 
# This file contains:
#   - SQL Server credentials
#   - Airtable API tokens
#   - SMTP passwords
#   - LLM API keys
#   - Reference data file paths
#
# NEVER commit ~/.siteowlqa/config.json to version control.
# NEVER put tokens or passwords in this .env file.
# =============================================================================

# --- Non-Sensitive Pipeline Behavior ----------------------------------------

# Poll interval (seconds) — how often to check Airtable for new submissions
POLL_INTERVAL_SECONDS=60

# Number of concurrent workers that grade submissions
# Each worker processes one submission at a time through the full pipeline
# Recommended: 2-4 depending on your SQL Server capacity
WORKER_THREADS=3

# Reference data source: "sql", "excel", or "auto"
# - sql   = fetch from SQL Server (ReferenceExport view)
# - excel = fetch from Excel workbook (path in user config)
# - auto  = prefer Excel if configured, fall back to SQL
REFERENCE_SOURCE=sql

# Email override for testing (leave blank for normal operation)
# If set, ALL outgoing emails go to this address instead of vendors
# EMAIL_OVERRIDE_TO=your.email@company.com

# --- Folder Paths (use absolute Windows paths with forward slashes) -----------

# Temporary files (auto-cleaned after processing)
TEMP_DIR=C:/SiteOwlQA_App/temp

# Generated CSVs and HTML dashboards
OUTPUT_DIR=C:/SiteOwlQA_App/output

# Rotating log files
LOG_DIR=C:/SiteOwlQA_App/logs

# Append-only archive of all submissions and executions
ARCHIVE_DIR=C:/SiteOwlQA_App/archive

# Raw vendor files (archived for audit trail)
SUBMISSIONS_DIR=C:/SiteOwlQA_App/archive/submissions

# --- Post-Pass Correction Output Directories --------------------------------
# Applies only to submissions with True Score >= 95.00.
# Files are labeled: {site_number}_{vendor_name}[_corrected|_correction_log|_raw]
#
# CORRECTED: corrected CSV in the original vendor submission schema
CORRECTION_CORRECTED_DIR=C:/Users/vn59j7j/OneDrive - Walmart Inc/Documents/BaselinePrinter/VUE Submissions/CORRECTED
#
# CORRECTION LOG: full audit trail of every correction attempt (primary artifact)
CORRECTION_LOG_DIR=C:/Users/vn59j7j/OneDrive - Walmart Inc/Documents/BaselinePrinter/VUE Submissions/CORRECTION LOG
#
# RAW: untouched copy of the original vendor file as submitted
CORRECTION_RAW_DIR=C:/Users/vn59j7j/OneDrive - Walmart Inc/Documents/BaselinePrinter/VUE Submissions/RAW
#
# Leave any of the above blank to fall back to: C:/SiteOwlQA_App/output/corrections/
#
# How often the autonomous CorrectionWorker polls Airtable (seconds).
# Lower = faster backfill of historical records. Default: 300 (5 minutes).
CORRECTION_POLL_INTERVAL_SECONDS=300
