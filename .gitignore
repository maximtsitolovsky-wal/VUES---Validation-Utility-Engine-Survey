# =============================================================================
# SiteOwlQA .gitignore — Enterprise Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Credentials (NEVER commit)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# GCP service account credentials
.secrets/
*-credentials.json
*-service-account.json

# User config (contains tokens)
.siteowlqa/

# Instance lock file
siteowlqa.lock

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
*.egg-info/
build/
dist/

# -----------------------------------------------------------------------------
# Runtime directories (generated data)
# -----------------------------------------------------------------------------
temp/
logs/
output/
archive/
served_dashboard/
share/

# Memory agent archive (nested — exempt from above)
!docs/memory-agent/store/archive/
!docs/memory-agent/store/archive/**

# -----------------------------------------------------------------------------
# Data files (may contain PII)
# -----------------------------------------------------------------------------
*.sqlite
*.db
*.csv
*.xlsx
*.xls
*.log

# -----------------------------------------------------------------------------
# OS generated
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/settings.json
.vscode/launch.json
*.code-workspace

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.swp
*~
move_files.py
fix_imports.py
scripts/*_output.txt
scripts/_*.txt
